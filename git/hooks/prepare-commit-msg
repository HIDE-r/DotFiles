#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# merge / squash / amend 等场景不要自动生成
case "$COMMIT_SOURCE" in
    merge|squash|commit)
        exit 0
        ;;
esac

# git commit -m "xxx" 时不要覆盖
if grep -q '^[^#[:space:]]' "$MSG_FILE"; then
    exit 0
fi

# 没有 staged diff 就退出
if git diff --cached --quiet; then
    exit 0
fi

TMP_PROMPT="$(mktemp)"
TMP_OUTPUT="$(mktemp)"
trap 'rm -f "$TMP_PROMPT" "$TMP_OUTPUT"' EXIT

{
    cat <<'EOF'
你是一个资深软件工程师。请根据下面的 staged git diff 生成一个 conventional commit 风格的 Git commit message 初稿。

要求：
1. 使用中文
2. 第一行是简短标题，建议不超过 50 个字
3. 如果改动较复杂，下面用 bullet list 说明重点
4. 不要编造 diff 中不存在的内容
5. 不要输出 Markdown 代码块
6. 不要解释，只输出 commit message
7. 风格类似：<模块>: <做了什么>

下面是 staged diff：
EOF

    printf '\n--- git diff --cached --stat ---\n'
    git diff --cached --stat

    printf '\n--- git diff --cached ---\n'
    git diff --cached --no-ext-diff --unified=3 | head -c 12000
} > "$TMP_PROMPT"

codex exec \
    --sandbox read-only \
    --ephemeral \
    --color never \
    -o "$TMP_OUTPUT" \
    - < "$TMP_PROMPT" >/dev/null 2>/dev/null || true

if [[ -s "$TMP_OUTPUT" ]]; then
    {
        cat "$TMP_OUTPUT"
        printf '\n\n'
        printf '# ------------------------\n'
        printf '# AI generated by codex exec. Please review before committing.\n'
    } > "$MSG_FILE"
fi
